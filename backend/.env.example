# ─── Firebird Database ───────────────────────────────────────────────────────
# Host waar de Firebird DB draait (zelfde VM = localhost)
FB_HOST=localhost
FB_PORT=3050
# Volledig pad naar het .fdb bestand op de server
FB_DATABASE=/opt/syntess/data/SYNTESS.FDB
# Dedicated read-only user (aanmaken via scripts/create-readonly-user.sql)
FB_USER=SYNTESS_RO
FB_PASSWORD=changeme_readonly_pass
# Tekenset — Syntess gebruikt doorgaans WIN1252 (Western European)
FB_CHARSET=WIN1252
# Connection pool
FB_POOL_MIN=2
FB_POOL_MAX=10
FB_POOL_IDLE_TIMEOUT=30000

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
# production | development
NODE_ENV=development
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
# Minimaal 32 tekens, willekeurige string
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h
# Beheerder account (MVP — single user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# ─── CORS ────────────────────────────────────────────────────────────────────
# Frontend origin(s), komma-gescheiden
CORS_ORIGINS=http://localhost:3000,https://rapport.jouwbedrijf.nl

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Globaal: requests per minuut per IP
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000
# Auth endpoint: pogingen per 15 minuten per IP
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
