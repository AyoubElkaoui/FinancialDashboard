# Firebird (Atrium) — on-prem LAN-machine
FB_HOST=192.168.1.100
FB_PORT=3050
# Services Atrium FDB (volledig Windows-pad op de server)
FB_DATABASE="C:\\_install\\Services\\12-01ATRIUM.FDB"
# Maintenance Atrium FDB (aparte file op zelfde server)
FB_DATABASE_MAINT="C:\\_install\\ELMM\\ATRIUM.FDB"
FB_USER=SYSDBA
FB_PASSWORD=masterkey
FB_CHARSET=WIN1252

# Postgres (Neon/Supabase — zelfde DATABASE_URL als frontend)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Configuratie
LOG_LEVEL=info
