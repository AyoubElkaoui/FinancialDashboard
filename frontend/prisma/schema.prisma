generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VIEWER
}

enum Database {
  SERVICES
  MAINTENANCE
  INTERNATIONAL
  KEYSER
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean        @default(false)
  role         Role           @default(VIEWER)
  databases    UserDatabase[]
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  ip        String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model UserDatabase {
  id       String   @id @default(cuid())
  userId   String
  database Database
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, database])
  @@index([userId])
}

model ProjectInput {
  id           String   @id @default(cuid())
  database     Database
  projectCode  String
  urenAantal   Float?
  urenTarief   Float?
  algKostenPct Float?
  opmerkingen  String?
  updatedBy    String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([database, projectCode])
  @@index([database])
}

model FormulaConfig {
  id        String   @id @default(cuid())
  database  Database
  scope     String
  encrypted String
  updatedBy String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([database, scope])
  @@index([database])
}

model DashboardPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  config    Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  action    String
  database  Database?
  detail    String?
  ip        String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Read-model: gesynchroniseerde Firebird-data ──────────────────────────────

model RmProjectSummary {
  id              String   @id @default(cuid())
  database        Database
  projectNr       String   @map("project_nr")
  naam            String
  klant           String   @default("")
  status          String   @default("ACTIEF")
  aanneemsom      Decimal  @default(0) @db.Decimal(15, 2)
  gefactureerd    Decimal  @default(0) @db.Decimal(15, 2)
  onbetaald       Decimal  @default(0) @db.Decimal(15, 2)
  kostenMateriaal Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_materiaal")
  kostenArbeid    Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_arbeid")
  kostenOverig    Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_overig")
  urenTotaal      Decimal  @default(0) @db.Decimal(10, 2) @map("uren_totaal")
  synctOp         DateTime @default(now()) @updatedAt @map("synct_op")

  @@unique([database, projectNr])
  @@index([database])
  @@map("rm_project_summary")
}

model RmJournaal {
  id            String   @id @default(cuid())
  database      Database
  projectNr     String   @map("project_nr")
  datum         DateTime
  rubriekCode   String   @map("rubriek_code")
  rubriekOmschr String   @map("rubriek_omschr")
  typeRubriek   String   @map("type_rubriek")
  debetCredit   String   @map("debet_credit")
  bedrag        Decimal  @db.Decimal(15, 2)
  omschrijving  String?

  @@index([database, projectNr])
  @@map("rm_journaal")
}

model RmUren {
  id           String   @id @default(cuid())
  database     Database
  projectNr    String   @map("project_nr")
  medewerker   String
  datum        DateTime
  aantal       Decimal  @db.Decimal(10, 2)
  omschrijving String?

  @@index([database, projectNr])
  @@map("rm_uren")
}

model RmSyncMeta {
  id             String   @id @default(cuid())
  database       Database @unique
  status         String   @default("pending")
  gesynctOp      DateTime @default(now()) @map("gesynct_op")
  duurMs         Int?     @map("duur_ms")
  projectenCount Int?     @map("projecten_count")
  fout           String?

  @@map("rm_sync_meta")
}
