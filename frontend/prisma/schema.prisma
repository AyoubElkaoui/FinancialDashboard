generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VIEWER
}

enum Database {
  SERVICES
  MAINTENANCE
  INTERNATIONAL
  KEYSER
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean        @default(false)
  role         Role           @default(VIEWER)
  databases    UserDatabase[]
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  ip        String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model UserDatabase {
  id       String   @id @default(cuid())
  userId   String
  database Database
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, database])
  @@index([userId])
}

model ProjectInput {
  id           String   @id @default(cuid())
  database     Database
  projectCode  String
  urenAantal   Float?
  urenTarief   Float?
  algKostenPct Float?
  opmerkingen  String?
  updatedBy    String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([database, projectCode])
  @@index([database])
}

model FormulaConfig {
  id        String   @id @default(cuid())
  database  Database
  scope     String
  encrypted String
  updatedBy String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([database, scope])
  @@index([database])
}

model DashboardPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  config    Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  action    String
  database  Database?
  detail    String?
  ip        String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}
