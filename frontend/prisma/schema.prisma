generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MGM
  VIEWER
}

enum Database {
  SERVICES
  MAINTENANCE
  INTERNATIONAL
  KEYSER
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean        @default(false)
  role         Role           @default(VIEWER)
  databases    UserDatabase[]
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  ip        String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model UserDatabase {
  id       String   @id @default(cuid())
  userId   String
  database Database
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, database])
  @@index([userId])
}

model ProjectInput {
  id           String   @id @default(cuid())
  database     Database
  projectCode  String
  urenAantal   Float?
  urenTarief   Float?
  algKostenPct Float?
  opmerkingen  String?
  updatedBy    String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([database, projectCode])
  @@index([database])
}

model FormulaConfig {
  id        String   @id @default(cuid())
  database  Database
  scope     String
  encrypted String
  updatedBy String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([database, scope])
  @@index([database])
}

model DashboardPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  config    Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  action    String
  database  Database?
  detail    String?
  ip        String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Werkbon read-model (Maintenance) ────────────────────────────────────────

model RmWerkbon {
  id               String   @id @default(cuid())
  database         Database
  bonnummer        String   @map("bonnummer")
  datum            DateTime @db.Date
  omschrijving     String?
  status           String   // A=Aangemaakt, I=In uitvoering, U=Uitgevoerd, V=Voltoooid
  methInUitvoering String?  @map("meth_in_uitvoering")  // W=Wacht uren, G=Gereed
  fase             String?
  klant            String?
  eigenaar         String?
  werkCode         String?  @map("werk_code")
  isGefactureerd   Boolean  @default(false) @map("is_gefactureerd")
  taakCode         String?  @map("taak_code")                        // AT_TAAK.GC_CODE -> techniek W/E/CV/B
  // Financiële velden uit DB (sync vult/overschrijft deze)
  opbrengsten      Decimal? @db.Decimal(12, 2)                       // AT_KLNTBREG sum per bon
  urenWerkbon      Decimal? @db.Decimal(10, 2) @map("uren_werkbon")  // AT_URENBREG per bon (23%)
  urenContract     Decimal? @db.Decimal(10, 2) @map("uren_contract") // AT_URENBREG contract-totaal (77%)
  synctOp          DateTime @default(now()) @updatedAt @map("synct_op")

  // Handmatig — ENIGE invulveld (sync raakt dit NOOIT aan)
  streefmargePct   Decimal? @db.Decimal(5, 2) @map("streefmarge_pct") // doelmarge %
  volledigBetaald  Boolean? @map("volledig_betaald")
  notities         String?

  @@unique([database, bonnummer])
  @@index([database, status])
  @@index([database, datum])
  @@index([database, klant])
  @@map("rm_werkbon")
}

// ─── Read-model: gesynchroniseerde Firebird-data ──────────────────────────────

model RmProjectSummary {
  id              String   @id @default(cuid())
  database        Database
  projectNr       String   @map("project_nr")
  naam            String
  klant           String   @default("")
  status          String   @default("ACTIEF")
  projectleider   String?  @map("projectleider")
  startdatum      DateTime? @db.Date @map("startdatum")
  aanneemsom      Decimal  @default(0) @db.Decimal(15, 2)
  gefactureerd    Decimal  @default(0) @db.Decimal(15, 2)
  onbetaald       Decimal  @default(0) @db.Decimal(15, 2)
  kostenMateriaal Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_materiaal")
  kostenArbeid    Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_arbeid")
  kostenOverig    Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_overig")
  kostenPakbon    Decimal  @default(0) @db.Decimal(15, 2) @map("kosten_pakbon")
  urenTotaal      Decimal  @default(0) @db.Decimal(10, 2) @map("uren_totaal")
  synctOp         DateTime @default(now()) @updatedAt @map("synct_op")

  @@unique([database, projectNr])
  @@index([database])
  @@index([database, projectleider])
  @@map("rm_project_summary")
}

model RmJournaal {
  id            String   @id @default(cuid())
  database      Database
  projectNr     String   @map("project_nr")
  datum         DateTime
  rubriekCode   String   @map("rubriek_code")
  rubriekOmschr String   @map("rubriek_omschr")
  typeRubriek   String   @map("type_rubriek")
  debetCredit   String   @map("debet_credit")
  bedrag        Decimal  @db.Decimal(15, 2)
  omschrijving  String?

  @@index([database, projectNr])
  @@map("rm_journaal")
}

model RmUren {
  id           String   @id @default(cuid())
  database     Database
  projectNr    String   @map("project_nr")
  medewerker   String
  datum        DateTime
  aantal       Decimal  @db.Decimal(10, 2)
  omschrijving String?

  @@index([database, projectNr])
  @@map("rm_uren")
}

model RmSyncMeta {
  id                String   @id @default(cuid())
  database          Database @unique
  status            String   @default("pending")
  gesynctOp         DateTime @default(now()) @map("gesynct_op")
  duurMs            Int?     @map("duur_ms")
  projectenCount    Int?     @map("projecten_count")
  totaalDebiteuren  Decimal? @db.Decimal(15, 2) @map("totaal_debiteuren")
  fout              String?

  @@map("rm_sync_meta")
}
